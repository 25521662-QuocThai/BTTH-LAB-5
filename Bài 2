// ========== CLASS TIME ==========
bool Time::KiemtraHopLe() const {
    // Giải thuật: Kiểm tra ngày tháng năm hợp lệ
    int ngayThang = 0;
    switch(thang) {
        case 4: case 6: case 9: case 11:
            ngayThang = 30;
            break;
        case 2:
            ngayThang = (nam % 400 == 0 || (nam % 100 != 0 && nam % 4 == 0)) ? 29 : 28;  
            break;
        default:
            ngayThang = 31;
    }
    
    if(ngay <= 0 || thang <= 0 || nam <= 0) return false;
    if(ngay > ngayThang) return false;
    if(thang > 12) return false;
    return true;
}

void Time::Nhap() {
    // Giải thuật: Nhập và kiểm tra ngày tháng năm
    cout << "Nhap ngay thang nam (DD MM YYYY): ";
    cin >> ngay >> thang >> nam;
    
    if(!KiemtraHopLe()) {  
        throw invalid_argument("Ngay thang nam khong hop le");
    }
}

void Time::Xuat() const {
    // Giải thuật: In ngày tháng năm
    cout << ngay << "/" << thang << "/" << nam;
}

