}

// ========== CLASS CONG TY ==========
void Congty::Nhap() {
    // Giải thuật: Vòng lặp → nhập loại → tạo object → nhập data
    int n;
    cout << "Nhap so luong giao dich: ";
    cin >> n;
    cin.ignore();  // xóa '\n'
    
    for(int i = 0; i < n; i++) {
        cout << "\n===== Giao dich " << i+1 << " =====" << endl;
        cout << "1=Dat_A, 2=Dat_B, 3=Dat_C, 4=Nha_CC, 5=Nha_T, 6=CanHo: ";
        int loai;
        cin >> loai;
        cin.ignore();  // xóa '\n'
        
        unique_ptr<GiaoDich> gd;
        
        switch(loai) {
            case 1: gd = make_unique<Dat_Loai_A>(); break;
            case 2: gd = make_unique<Dat_Loai_B>(); break;
            case 3: gd = make_unique<Dat_Loai_C>(); break;
            case 4: gd = make_unique<Nha_Cao_Cap>(); break;
            case 5: gd = make_unique<Nha_Thuong>(); break;
            case 6: gd = make_unique<CanHoChungCu>(); break;
            default:
                cout << "Khong hop le!\n";
                i--;
                continue;
        }
        
        gd->Nhap();
        dsGiaoDich.push_back(move(gd));
    }
}

void Congty::Xuat() const {
    // Giải thuật: Kiểm tra rỗng → duyệt → in từng giao dịch
    if(dsGiaoDich.empty()) {
        cout << "Danh sach rong!\n";
        return;
    }
    
    cout << "\n========= DANH SACH GIAO DICH =========\n";
    for(auto& gd : dsGiaoDich) {
        gd->Xuat();
    }
}
// Hàm xuất những giao dịch vào tháng 12 năm 2024
void Congty::XuatGD_12_2024() const {
    // Giải thuật: Duyệt → so sánh tháng/năm → in nếu là 12/2024
    cout << "\n===== GIAO DICH THANG 12/2024 =====" << endl;
    bool found = false;
    
    for(auto& gd : dsGiaoDich) {
        Time t = gd->getNgayGD();
        if(t.getThang() == 12 && t.getNam() == 2024) {
            gd->Xuat();
            found = true;
        }
    }
    
    if(!found) cout << "Khong co giao dich thang 12/2024!\n";
}
// Hàm tính số lượng từng loại 
void Congty::LuongGDTungLoai() const {
    // Giải thuật: Dynamic cast lọc từng loại → đếm
    int datA = 0, datB = 0, datC = 0, nhaCap = 0, nhaT = 0, canHo = 0;
    
    for(auto& gd : dsGiaoDich) {
        if(dynamic_cast<Dat_Loai_A*>(gd.get())) datA++;
        else if(dynamic_cast<Dat_Loai_B*>(gd.get())) datB++;
        else if(dynamic_cast<Dat_Loai_C*>(gd.get())) datC++;
        else if(dynamic_cast<Nha_Cao_Cap*>(gd.get())) nhaCap++;
        else if(dynamic_cast<Nha_Thuong*>(gd.get())) nhaT++;
        else if(dynamic_cast<CanHoChungCu*>(gd.get())) canHo++;
    }
    
    cout << "\n===== SO LUONG GIAO DICH TUNG LOAI =====" << endl;
    cout << "Dat loai A: " << datA << endl;
    cout << "Dat loai B: " << datB << endl;
    cout << "Dat loai C: " << datC << endl;
    cout << "Nha cao cap: " << nhaCap << endl;
    cout << "Nha thuong: " << nhaT << endl;
    cout << "Can ho: " << canHo << endl;
}
// Hàm tình giá trung bình căn hộ
void Congty::GiaTrungBinhCanHo() const {
    // Giải thuật: Dynamic cast lọc CanHo → tính TB = Tổng / Số lượng
    double tongTien = 0;
    int count = 0;
    
    for(auto& gd : dsGiaoDich) {
        if(dynamic_cast<CanHoChungCu*>(gd.get())) {
            tongTien += gd->Tongtien();
            count++;
        }
    }
    
    if(count > 0) {
        cout << "\n===== GIA TRUNG BINH CAN HO =====" << endl;
        cout << "Trung binh: " << fixed << setprecision(0) << (tongTien / count) << endl;
    } else {
        cout << "Khong co can ho!\n";
    }
}
// Hàm tìm nhà phố có giá trị lớn nhất 
void Congty::MaxGiaTheTich_NhaPhong() const {
    // Giải thuật: Dynamic cast lọc nhà phố → Linear search MAX
    double maxTien = 0;
    int indexMax = -1;
    
    for(int i = 0; i < dsGiaoDich.size(); i++) {
        if(dynamic_cast<Nha_Cao_Cap*>(dsGiaoDich[i].get()) || 
           dynamic_cast<Nha_Thuong*>(dsGiaoDich[i].get())) {
            if(dsGiaoDich[i]->Tongtien() > maxTien) {
                maxTien = dsGiaoDich[i]->Tongtien();
                indexMax = i;
            }
        }
    }
    
    if(indexMax != -1) {
        cout << "\n===== NHA PHO GIA CAO NHAT =====" << endl;
        dsGiaoDich[indexMax]->Xuat();
    } else {
        cout << "Khong co nha pho!\n";
    }
}

