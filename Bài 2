bool Time::KiemtraHopLe() const{
    int ngayThang = 0;
    switch(thang){
        case 4: case 6: case 9: case 11: 
        ngayThang = 30 ;
        break ;
        case 2:
        ngayThang = (nam % 400 ==0 || (nam % 100 != 0 && nam & 4 ==0)) ? 29:28 ;
        break ;
        default: ngayThang = 31 ;
         
    }
    if( ngay < 0 || thang < 0 || nam < 0) return false ;
    else if( ngay > ngayThang) return false ;
    else if( thang > 12) return false ;
    else return true ;
}
void Time::Nhap(){
    cout <<" Nhap ngay thang nam: " ;
    cin >> ngay >> thang >> nam ;
    if(KiemtraHopLe()){
        throw invalid_argument(" Ngay Thang Nam khong hop le ");
     
}
void Time::Xuat() const {
    cout << ngay <<"/"<< thang<< "/" << nam ;
}
