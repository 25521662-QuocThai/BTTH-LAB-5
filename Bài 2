// ========== CLASS TIME ==========
class Time {
    private:
    int ngay, thang, nam;
    bool KiemtraHopLe() const ;
    public:
    // CONSTRUCTOR
    Time() : ngay(0), thang(0), nam(0) {}
    Time(int d, int m, int y) : ngay(d), thang(m), nam(y) {}
    
    // GETTER
    int getThang() const { return thang; }
    int getNam() const { return nam; }
    
    void Nhap();
    void Xuat() const;
};

// CLASS GIAODICH (BASE CLASS)
class GiaoDich {
    protected:
    string ma_GD;
    Time ngayGD;
    double DonGia;
    double DienTich;
    
    public:
    // CONSTRUCTOR
    GiaoDich() : ma_GD(""), DonGia(0), DienTich(0) {}
    virtual ~GiaoDich() {}
    
    
    virtual void Nhap();
    virtual void Xuat() const;
    
    
    virtual double Tongtien() const = 0;
    
    
    Time getNgayGD() const { return ngayGD; }
    
};

