// CLASS NHAN VIEN VAN PHONG
void NhanVienVanPhong::Nhap() override {
    cout<<"=====Nhap thong tin nhan vien van phong=======" << endl ;
    NhanVien::Nhap() ;
    cout <<" So ngay lam viec: " ;
    cin >> SoNgayLam ;
}
void NhanVienVanPhong::Xuat() const override {
    cout<<"=====Thong tin nhan vien van phong=======" << endl ;
    NhanVien::Xuat() ;
    cout <<"\n So ngay lam viec: " << SoNgayLam << endl ;
    cout <<"\n Luong:" << tinhLuong() << endl;
}
float NhanVienVanPhong::tinhLuong() const override {
    return SoNgayLam * 100000 ;
}
// CLASS NHAN VIEN SAN XUAT 
void NhanVienSanXuat::Nhap() override {
    cout<<"=====Nhap thong tin nhan vien san xuat=======" << endl ;
    NhanVien::Nhap();
    cout <<" luong co ban:" ;
    cin >> LuongCanBan;
    cout <<" so san pham:" ;
    cin >> SoSanPham ;
}
void NhanVienSanXuat::Xuat() const override {
    cout<<"=====Thong tin nhan vien san xuat=======" << endl ;
    NhanVien::Xuat() ;
    cout <<"\n Luong co ban: " << LuongCanBan ;
    cout <<"\n So san pham: " << SoSanPham ;
    cout <<"\n Luong: " << tinhLuong() << endl ;
}
float NhanVienSanXuat::tinhLuong() const override {
    return LuongCanBan + SoSanPham * 5000 ;
}
// CLASS CONG TY 
void CongTy::Nhapds(){
    cout <<" Nhap so luong nhan vien: " ;
    int n ;
    cin >> n ;
    int loai ;
    
    for(int i = 0; i < n ; i++){
        cout <<" Nhap loai nhan vien(1= San Xuat, 2= Van Phong) " << endl ;
        cin >> loai ;
        cin.ignore();
        // Tạo unique_ptr chứa NhanVienVanPhong
        if(loai == 1){
            unique_ptr<NhanVien> nv = make_unique<NhanVienSanXuat>() ;
            nv->Nhap() ;
            dsNhanVien.push_back(move(nv)) ;
        }
        // Tạo unique_ptr chứa NhanVienSanXuat
        if(loai == 2){
            unique_ptr<NhanVien> nv = make_unique<NhanVienVanPhong>() ;
            nv->Nhap() ;
            dsNhanVien.push_back(move(nv)) ; // move: chuyen vao vector
        }
    }
}
void CongTy::Xuatds(){
    if(dsNhanVien.empty()){
        cout <<" Danh sach rong! " << endl ;
        return ;
    }
    cout<<"======Danh sach nhan vien =========" << endl ;
    for(int i = 0 ; i < dsNhanVien.size(); i++){
        cout <<" -Nhan vien " << i+1 << endl ;
        dsNhanVien[i]->Xuat();
    }
}
float CongTy::tinhTongLuong(){
    for(int i = 0 ; i < dsNhanVien.size(); i++){
        dsNhanVien.Luong += dsNhanVien[i]->tinhLuong() ;
    }
    return dsNhanVien.Luong ;
}
