#ifndef NHANVIEN_H
#define NHANVIEN_H
#include <iostream>
#include <vector>
#include <cstring>
using namespace std;

class NhanVien{
    protected:
    string HovaTen;
    string NgaySinh ;
    double Luong ;
    
    public:
    
    NhanVien() {}
    NhanVien(string ten, string d , double tien): HovaTen(ten), NgaySinh(d), Luong(tien){}
    virtual ~NhanVien() {}
    
    virtual void Nhap() ;
    virtual void Xuat() const ;
    virtual float tinhLuong() const = 0;
    
};
class NhanVienVanPhong : public NhanVien {
    private:
    int SoNgayLam ;
    
    public:
    
    NhanVienVanPhong(): NhanVien("","",0), SoNgayLam(0) {}
    ~NhanVienVanPhong() {}
    
    void Nhap() override;
    void Xuat() const override ;
    float tinhLuong() const override;
};
class NhanVienSanXuat : public NhanVien {
    private:
    int LuongCanBan ;
    int SoSanPham ;
    
    public:
    
    NhanVienSanXuat(): NhanVien("","",0), LuongCanBan(0), SoSanPham(0) {}
    ~NhanVienSanXuat() {}
    
    void Nhap() override;
    void Xuat() const override;
    float tinhLuong() const override;
};
class CongTy{
    private:
    vector<unique_ptr<NhanVien>> dsNhanVien ;
    
    public:
    CongTy() {}
    CongTy(): dsNhanVien(0) {}
    ~CongTy() {}
    
    void Nhapds();
    void Xuatds();
    float tinhTongLuong() ;
    float minLuongnvSanXuat() ;
    void maxTuoinvVanPhong() ;
};
#endif 

