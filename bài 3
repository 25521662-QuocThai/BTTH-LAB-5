class SinhVien{
    protected:
    string HovaTen ;
    string ma_Sv ;
    string address ;
    int SoChi ;
    double DiemTb ;
    
    public:
    SinhVien(): HovaTen(""), ma_Sv(""), address(""), SoChi(0), DiemTb(0) {}
    virtual ~SinhVien() {} 
    
    virtual void Nhap() ;
    virtual void Xuat() const ;
};

